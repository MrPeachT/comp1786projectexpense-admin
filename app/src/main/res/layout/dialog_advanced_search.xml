<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/etAdvancedKeyword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Keyword (name or description)" />

    <Spinner
        android:id="@+id/spinnerAdvancedStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp" />

    <EditText
        android:id="@+id/etAdvancedManager"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Project manager / owner" />

    <EditText
        android:id="@+id/etAdvancedStartDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Start date (YYYY-MM-DD)" />
</LinearLayout>