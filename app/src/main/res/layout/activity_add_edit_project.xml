<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Project"
            android:textColor="@color/blue_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Enter project details below"
            android:textColor="@color/blue_subtext"
            android:textSize="14sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/imgProjectFormPreview"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:adjustViewBounds="true"
                    android:background="@android:color/darker_gray"
                    android:contentDescription="Selected project image"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnChooseProjectImage"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/blue_accent"
                        android:text="Choose Image"
                        android:textAllCaps="false"
                        android:textColor="@color/blue_primary_dark" />

                    <Button
                        android:id="@+id/btnRemoveProjectImage"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/blue_primary_dark"
                        android:text="Remove Image"
                        android:textAllCaps="false"
                        android:textColor="@color/white" />
                </LinearLayout>

                <EditText
                    android:id="@+id/etProjectCode"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/blue_primary"
                    android:hint="Project Code"
                    android:textColor="@color/blue_text"
                    android:textColorHint="@color/blue_subtext" />

                <EditText
                    android:id="@+id/etProjectName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/blue_primary"
                    android:hint="Project Name"
                    android:textColor="@color/blue_text"
                    android:textColorHint="@color/blue_subtext" />

                <EditText
                    android:id="@+id/etProjectDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/blue_primary"
                    android:gravity="top"
                    android:hint="Project Description"
                    android:minLines="3"
                    android:textColor="@color/blue_text"
                    android:textColorHint="@color/blue_subtext" />

                <EditText
                    android:id="@+id/etStartDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/blue_primary"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Start Date"
                    android:textColor="@color/blue_text"
                    android:textColorHint="@color/blue_subtext" />

                <EditText
                    android:id="@+id/etEndDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/blue_primary"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="End Date"
                    android:textColor="@color/blue_text"
                    android:textColorHint="@color/blue_subtext" />

                <EditText
                    android:id="@+id/etProjectManager"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/blue_primary"
                    android:hint="Project Manager / Owner"
                    android:textColor="@color/blue_text"
                    android:textColorHint="@color/blue_subtext" />

                <Spinner
                    android:id="@+id/spinnerProjectStatus"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp" />

                <EditText
                    android:id="@+id/etProjectBudget"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/blue_primary"
                    android:hint="Project Budget"
                    android:inputType="numberDecimal"
                    android:textColor="@color/blue_text"
                    android:textColorHint="@color/blue_subtext" />

                <EditText
                    android:id="@+id/etSpecialRequirements"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/blue_primary"
                    android:hint="Special Requirements (Optional)"
                    android:textColor="@color/blue_text"
                    android:textColorHint="@color/blue_subtext" />

                <EditText
                    android:id="@+id/etClientInfo"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/blue_primary"
                    android:hint="Client / Department Info (Optional)"
                    android:textColor="@color/blue_text"
                    android:textColorHint="@color/blue_subtext" />

                <Button
                    android:id="@+id/btnSaveProject"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="18dp"
                    android:backgroundTint="@color/blue_primary"
                    android:text="Save Project"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>